{
  "version": 1,
  "min_title_chars": 5,
  "min_title_words": 2,
  "default_group": "todo",
  "group_markers": {
    "not-do": [
      "not do",
      "не делать",
      "не смотреть",
      "избегать"
    ],
    "anti-todo": [
      "anti-todo",
      "анти-туду"
    ]
  },
  "stop_prefixes": [
    "поставь задачу",
    "поставьте задачу",
    "запиши",
    "запишите",
    "добавь",
    "добавьте",
    "добавить",
    "задача",
    "на туду",
    "в туду",
    "на todo",
    "в todo",
    "todo",
    "to do",
    "мне",
    "пожалуйста"
  ],
  "tail_words": [
    "и",
    "а"
  ],
  "drop_exact": [
    "новая задача",
    "задача",
    "сделать"
  ],
  "month_names_ru": {
    "января": 1,
    "февраля": 2,
    "марта": 3,
    "апреля": 4,
    "мая": 5,
    "июня": 6,
    "июля": 7,
    "августа": 8,
    "сентября": 9,
    "октября": 10,
    "ноября": 11,
    "декабря": 12
  }
}
