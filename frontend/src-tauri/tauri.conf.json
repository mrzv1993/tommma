{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tommma",
  "version": "1.3.0",
  "identifier": "ru.tommma.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev --mode tauri --host 127.0.0.1 --port 5173",
    "beforeBuildCommand": "pnpm build --mode tauri",
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Tommma",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM1MzQ4RDlEMUJGNDY3QUEKUldTcVovUWJuWTAweGJxaG9pa2RIaVcwSTB4N1BzUXdjZCthdkNpSi9SWHl6cjNsZk9ZZ3RjVFUK",
      "endpoints": [
        "https://github.com/mrzv1993/tommma/releases/latest/download/latest.json"
      ]
    }
  }
}
